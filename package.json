{
  "name": "@alternative-design-and-media/rentman-api-connector",
  "version": "1.0.0",
  "description": "Type-safe Rentman REST API client for Node.js and edge runtimes (Cloudflare Workers). Synced to OAS v1.7.0.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "docs:ai": "node scripts/generate-ai-docs.mjs",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "rentman",
    "api",
    "client",
    "typescript",
    "mcp",
    "cloudflare-workers"
  ],
  "author": "Alternative Design and Media",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alternative-Design-And-Media/rentman-api-connector.git"
  },
  "bugs": {
    "url": "https://github.com/Alternative-Design-And-Media/rentman-api-connector/issues"
  },
  "homepage": "https://github.com/Alternative-Design-And-Media/rentman-api-connector#readme",
  "peerDependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
